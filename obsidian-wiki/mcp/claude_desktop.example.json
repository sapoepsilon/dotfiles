{
  "_comment": "Merge the 'mcpServers' object below into ~/Library/Application Support/Claude/claude_desktop_config.json. Preserve any existing 'preferences' key.",
  "mcpServers": {
    "obsidian": {
      "command": "/opt/homebrew/bin/uvx",
      "args": ["mcp-obsidian"],
      "env": {
        "OBSIDIAN_API_KEY": "REPLACE_WITH_KEY_FROM_LOCAL_REST_API_PLUGIN",
        "OBSIDIAN_HOST": "127.0.0.1",
        "OBSIDIAN_PORT": "27124",
        "OBSIDIAN_PROTOCOL": "https"
      }
    },
    "filesystem-vault": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "REPLACE_WITH_LOCAL_VAULT_PATH"
      ]
    },
    "vault-fs-remote": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "http://<your-lxc-ip>:9876/servers/vault-fs/sse"
      ]
    }
  }
}
